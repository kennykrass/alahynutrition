generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PATIENT
}

enum BiologicalSex {
  MALE
  FEMALE
}

enum PhysicalActivityLevel {
  NONE
  LIGHT
  MODERATE
  INTENSE
}

enum PatientStatus {
  NEW
  ACTIVE
  PENDING
  ARCHIVED
  EXPIRED
}

enum CareType {
  INITIAL
  FOLLOW_UP
  RESTART
}

enum PlanDuration {
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  CUSTOM
}

enum PatientDocumentCategory {
  LAB_RESULT
  INDICATION
  RECIPE
  PREVIOUS_PLAN
}

enum AppointmentType {
  INITIAL
  FOLLOW_UP
  RESTART
  VIDEO_CALL
  PHONE_CALL
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  RESCHEDULE_REQUESTED
  COMPLETED
  MISSED
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id                 String            @id @default(cuid())
  fullName           String
  email              String            @unique
  passwordHash       String
  mustChangePassword Boolean           @default(false)
  role               UserRole          @default(PATIENT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  profile            PatientProfile?
  entries            ProgressEntry[]
  documents          PatientDocument[]
  appointments       Appointment[]
}

model PatientProfile {
  id                     String                 @id @default(cuid())
  userId                 String                 @unique
  patientCode            String?                @unique
  phone                  String?
  birthDate              DateTime?
  biologicalSex          BiologicalSex?
  heightCm               Float?
  initialWeightKg        Float?
  currentWeightKg        Float?
  previousDietExperience Boolean?
  previousDietDuration   String?
  physicalActivityLevel  PhysicalActivityLevel?
  status                 PatientStatus          @default(NEW)
  careType               CareType?
  planDuration           PlanDuration?
  contactSchedule        String?
  medications            String?
  foodAllergies          String?
  goal                   String?
  notes                  String?
  acceptedPrivacyAt      DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressEntry {
  id         String   @id @default(cuid())
  userId     String
  loggedAt   DateTime @default(now())
  weightKg   Float?
  waistCm    Float?
  bodyFatPct Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt(sort: Desc)])
}

model PatientDocument {
  id             String                  @id @default(cuid())
  userId         String
  category       PatientDocumentCategory
  title          String
  originalName   String
  mimeType       String
  sizeBytes      Int
  fileData       Bytes
  uploadedByRole UserRole
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category, createdAt(sort: Desc)])
}

model Appointment {
  id                   String            @id @default(cuid())
  userId               String
  type                 AppointmentType
  status               AppointmentStatus @default(REQUESTED)
  scheduledAt          DateTime
  durationMinutes      Int
  notes                String?
  isFlexibleRequest    Boolean           @default(false)
  requestedScheduledAt DateTime?
  requestedChangeNote  String?
  createdByRole        UserRole
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledAt(sort: Desc)])
  @@index([status, scheduledAt(sort: Asc)])
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  dayOfWeek WeekDay
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayOfWeek, isActive])
}

model FoodGroup {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  shortName         String
  icon              String
  sortOrder         Int                @default(0)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  recipeEquivalents RecipeEquivalent[]

  @@index([isActive, sortOrder])
}

model Recipe {
  id          String             @id @default(cuid())
  title       String
  mealType    String
  description String
  prepMinutes Int
  imageUrl    String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  equivalents RecipeEquivalent[]

  @@index([mealType, isActive])
}

model RecipeEquivalent {
  id          String    @id @default(cuid())
  recipeId    String
  foodGroupId String
  amount      Float
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodGroup   FoodGroup @relation(fields: [foodGroupId], references: [id], onDelete: Cascade)

  @@unique([recipeId, foodGroupId])
  @@index([foodGroupId])
}

model FoodCatalogItem {
  id              String   @id @default(cuid())
  source          String
  sourcePage      Int
  groupName       String
  groupSlug       String
  foodName        String
  suggestedAmount String?
  unit            String?
  grossWeightG    Float?
  netWeightG      Float?
  energyKcal      Float?
  proteinG        Float?
  lipidsG         Float?
  carbsG          Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([source, sourcePage, foodName, suggestedAmount, unit])
  @@index([groupSlug])
  @@index([foodName])
}
